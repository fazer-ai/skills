# Copy to .env and fill in. .env is gitignored.

# Verdaccio admin token. Get via:
#   curl -fsS -X POST -H 'Content-Type: application/json' \
#     -d '{"name":"ADMIN_USER","password":"ADMIN_PWD"}' \
#     https://npm.fazer.ai/-/v1/login
VERDACCIO_ADMIN_TOKEN=

# GitHub fine-grained PAT with Contents: Write and Pull requests: Write
# on fazer-ai/skills. Shared across all plugin repos.
SKILLS_REPO_PAT=

# Optional overrides.
# VERDACCIO_REGISTRY=https://npm.fazer.ai
# VERDACCIO_USER_EMAIL=ops@fazer.ai
