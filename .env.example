# Copy to .env and fill in. .env is gitignored.

# Verdaccio admin token. Get via:
#   curl -fsS -X POST -H 'Content-Type: application/json' \
#     -d '{"name":"ADMIN_USER","password":"ADMIN_PWD"}' \
#     https://npm.fazer.ai/-/v1/login
VERDACCIO_ADMIN_TOKEN=

# Per-repo GitHub PATs (fine-grained, Contents: Write + Pull requests: Write
# on fazer-ai/skills). Variable name = uppercase repo name with hyphens
# converted to underscores, suffixed with _PAT.
#   fazer-ai-atendimento  -> FAZER_AI_ATENDIMENTO_PAT
#   fazer-ai-negocio      -> FAZER_AI_NEGOCIO_PAT
#   fazer-ai-vps          -> FAZER_AI_VPS_PAT
#   fazer-ai-agentes      -> FAZER_AI_AGENTES_PAT
#   fazer-ai-skills-dev   -> FAZER_AI_SKILLS_DEV_PAT
FAZER_AI_VPS_PAT=
FAZER_AI_AGENTES_PAT=
FAZER_AI_SKILLS_DEV_PAT=

# Optional overrides.
# VERDACCIO_REGISTRY=https://npm.fazer.ai
# VERDACCIO_USER_EMAIL=ops@fazer.ai
